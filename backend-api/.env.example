# Render backend settings

# Paste the INTERNAL Database URL from your Render Postgres instance here.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Set to false for the internal Render Postgres URL in most cases.
# Set to true only if your chosen connection requires SSL.
DATABASE_SSL=false

# Auto-create the schema on startup.
AUTO_RUN_MIGRATIONS=true

# Optional: comma-separated list of allowed frontend origins.
# Leave empty to allow all origins while testing.
# Example:
# FRONTEND_ORIGIN=https://your-frontend.onrender.com
FRONTEND_ORIGIN=
